                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>PAR_ERR</name>
                                    <description>The parity of the received data character doesn't correspond to the settings of the EPS and SPS bits in the LCR_H register</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
