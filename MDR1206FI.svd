        <peripheral>
            <name>CLINT</name>
            <description>Core Local Interruptor</description>
            <groupName>CLINT</groupName>
            <baseAddress>0x02000000</baseAddress>
            <addressBlock>
                <offset>0x00000000</offset>
                <size>0x4</size>
                <usage>registers</usage>
            </addressBlock>
            <addressBlock>
                <offset>0x00004000</offset>
                <size>0x8</size>
                <usage>registers</usage>
            </addressBlock>
            <addressBlock>
