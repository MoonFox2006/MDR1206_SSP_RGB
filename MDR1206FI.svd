                <name>TIMER1_IRQ</name>
                <value>6</value>
            </interrupt>
            <registers>
                <register>
                    <name>CNT</name>
                    <displayName>CNT</displayName>
                    <description>Counter</description>
                    <addressOffset>0x00000000</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields/>
                </register>
                <register>
                    <name>PSG</name>
                    <displayName>PSG</displayName>
                    <description>Prescaler value. TIM_CLKd = TIM_CLK/(PSG+1)</description>
                    <addressOffset>0x00000004</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                </register>
                <register>
                    <name>ARR</name>
                    <displayName>ARR</displayName>
                    <description>Auto-reload register</description>
                    <addressOffset>0x00000008</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields/>
                </register>
                <register>
                    <name>CNTRL</name>
                    <displayName>CNTRL</displayName>
                    <description>Control register</description>
                    <addressOffset>0x0000000C</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>CNT_EN</name>
                            <description>Enables operation of the timer</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>ARRB_EN</name>
                            <description>Renewal of the ARR</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>ARRB_EN_0</name>
                                    <description>ARR is rewritten when there is a write in ARR</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>ARRB_EN_1</name>
                                    <description>ARR is rewritten when CNT == ARR</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>WR_CMPL</name>
                            <description>Flag denotes if a new value can be written in CNT, PSG, ARR. 1 - writing is in process</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-only</access>
                        </field>
                        <field>
                            <name>DIR</name>
                            <description>Direction</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Direct</name>
                                    <description>From 0 to ARR</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Backward</name>
                                    <description>From ARR to 0</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>FDTS</name>
                            <description>Clock frequency FDTS</description>
                            <bitOffset>4</bitOffset>
                            <bitWidth>2</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>TIM_CLK</name>
                                    <description>FDTS = TIM_CLK</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM_CLK_2</name>
                                    <description>FDTS = TIM_CLK/2</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM_CLK_3</name>
                                    <description>FDTS = TIM_CLK/3</description>
                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM_CLK_4</name>
                                    <description>FDTS = TIM_CLK/4</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CNT_MODE</name>
                            <description>Counter mode</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>2</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>MODE_00</name>
                                    <description>Direct when DIR=0, backward when DIR=1</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>MODE_01</name>
                                    <description>Bidirectional with automatic change of DIR when CNT == 0 or CNT == ARR</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>MODE_10</name>
                                    <description>Direct when DIR=0, backward when DIR=1</description>
                                    <value>0x2</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>EVNT_SEL</name>
                            <description>Selects a source which triggers events</description>
                            <bitOffset>8</bitOffset>
                            <bitWidth>4</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Int_CLOCK</name>
                                    <description>TIM_CLKd</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM1</name>
                                    <description>CNT == ARR in Timer1</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM2</name>
                                    <description>CNT == ARR in Timer2</description>
                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM3</name>
                                    <description>CNT == ARR in Timer3</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH1</name>
                                    <description>Rising edge, mode 1</description>
                                    <value>0x4</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH2</name>
                                    <description>Rising edge, mode 1</description>
                                    <value>0x5</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH3</name>
                                    <description>Rising edge, mode 1</description>
                                    <value>0x6</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH4</name>
                                    <description>Rising edge, mode 1</description>
                                    <value>0x7</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>ETR_POS</name>
                                    <description>Rising edge, mode 2</description>
                                    <value>0x8</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>ETR_NEG</name>
                                    <description>Falling edge, mode 2</description>
                                    <value>0x9</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TIM4</name>
                                    <description>CNT == ARR in Timer4</description>
                                    <value>0xA</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                    </fields>
