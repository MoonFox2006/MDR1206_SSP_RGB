                            <name>MASTER_ENABLE</name>
                            <description>Enables the status of the controller</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-only</access>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>The controller is disabled</name>
                                    <value>0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>The controller is enabled</name>
                                    <value>1</value>
                                </enumeratedValue>
                            </enumeratedValues>
