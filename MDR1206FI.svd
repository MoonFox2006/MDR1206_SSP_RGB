                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_USEBURST_CLR</name>
                    <displayName>CHNL_USEBURST_CLR</displayName>
                    <description>Channel useburst clear. Set the appropriate bit to enable dma_sreq[] to generate requests</description>
                    <addressOffset>0x0000001C</addressOffset>
                    <access>write-only</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_REQ_MASK_SET</name>
                    <displayName>CHNL_REQ_MASK_SET</displayName>
                    <description>Channel request mask set. Returns the request mask status of dma_req[] and dma_sreq[], or disables the
corresponding channel from generating DMA requests</description>
                    <addressOffset>0x00000020</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_REQ_MASK_CLR</name>
                    <displayName>CHNL_REQ_MASK_CLR</displayName>
                    <description>Channel request mask clear. Set the appropriate bit to enable DMA requests for the channel corresponding to
dma_req[] and dma_sreq[].</description>
                    <addressOffset>0x00000024</addressOffset>
                    <size>0x20</size>
                    <access>write-only</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_ENABLE_SET</name>
                    <displayName>CHNL_ENABLE_SET</displayName>
                    <description>Channel enable set. Returns the enable status of the channels, or enables the corresponding channels</description>
                    <addressOffset>0x00000028</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_ENABLE_CLR</name>
                    <displayName>CHNL_ENABLE_CLR</displayName>
                    <description>Sets the appropriate bit to disable the corresponding DMA channel</description>
                    <addressOffset>0x0000002C</addressOffset>
                    <size>0x20</size>
                    <access>write-only</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_PRI_ALT_SET</name>
                    <displayName>CHNL_PRI_ALT_SET</displayName>
                    <description>Channel primary-alternate set register enables you to configure a DMA channel to use the alternate data structure or returns the channel control data structure status.</description>
                    <addressOffset>0x00000030</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_PRI_ALT_CLR</name>
                    <displayName>CHNL_PRI_ALT_CLR</displayName>
                    <description>Channel primary-alternate clear register enables you to configure a DMA channel to use the primary data structure</description>
                    <addressOffset>0x00000034</addressOffset>
                    <size>0x20</size>
                    <access>write-only</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_PRIORITY_SET</name>
                    <displayName>CHNL_PRIORITY_SET</displayName>
                    <description>Channel priority set enables you to configure a DMA channel to use the high priority level. Reading the register returns the status of the channel priority mask.</description>
                    <addressOffset>0x00000038</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                </register>
                <register derivedFrom="CHNL_USEBURST_SET">
                    <name>CHNL_PRIORITY_CLR</name>
                    <displayName>CHNL_PRIORITY_CLR</displayName>
                    <description>Channel priority clear register enables you to configure a DMA channel to use the default priority level</description>
                    <addressOffset>0x0000003C</addressOffset>
                    <size>0x20</size>
                    <access>write-only</access>
                </register>
                <register>
                    <name>ERR_CLR</name>
                    <displayName>ERR_CLR</displayName>
                    <description>Error clear register enables you to set dma_err LOW</description>
                    <addressOffset>0x0000004C</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>ERR_CLR</name>
                            <description>Returns the status of dma_err, or sets the signal LOW</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-write</access>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>
        <peripheral>
            <name>I2C</name>
            <description>I2C Controller</description>
            <groupName>I2C</groupName>
            <baseAddress>0x50030000</baseAddress>
            <addressBlock>
                <offset>0x0</offset>
                <size>0x00001000</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>I2C_IRQ</name>
                <value>9</value>
            </interrupt>
            <registers>
                <register>
                    <name>PRL</name>
                    <displayName>PRL</displayName>
                    <description>Lower part of the prescaler</description>
                    <addressOffset>0x00000000</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>PR</name>
                            <description>Lower part of the prescaler</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>PRH</name>
                    <displayName>PRH</displayName>
                    <description>Higher part of the prescaler</description>
                    <addressOffset>0x00000004</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>PR</name>
                            <description>Higher part of the prescaler</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CTR</name>
                    <displayName>CTR</displayName>
                    <description>I2C Control Register</description>
                    <addressOffset>0x00000008</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>EN_INT</name>
                            <description>Enables the interrupt generated by the I2C</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>EN_I2C</name>
                            <description>Enables I2C operation</description>
                            <bitOffset>7</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>RXD</name>
                    <displayName>RXD</displayName>
                    <description>Received Data Register</description>
                    <addressOffset>0x0000000C</addressOffset>
                    <size>0x20</size>
                    <access>read-only</access>
                    <fields>
                        <field>
                            <name>RXD</name>
                            <description>The last received byte</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>STA</name>
                    <displayName>STA</displayName>
                    <description>Status Register</description>
                    <addressOffset>0x00000010</addressOffset>
                    <size>0x20</size>
                    <access>read-only</access>
                    <fields>
                        <field>
                            <name>INT</name>
                            <description>Interrupt flag</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>No_Int</name>
                                    <description>Selects ACLK as the clock source</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Int_Present</name>
                                    <description>There is an interrupt. Either a byte has been transmitted
                                    or the arbitration has been lost</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>TR_PROG</name>
                            <description>The state of the transmission</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Completed</name>
                                    <description>Data transmission is completed</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>In Progress</name>
                                    <description>Data transmission is in progress</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>LOST_ARB</name>
                            <description>The loss of the arbitration</description>
                            <bitOffset>5</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>ARB_Present</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>ARB_Lost</name>
                                    <description>The arbitration has been lost. Stop bit has been received without initialization or
                                    SDA must be set as high but it is low</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>BUSY</name>
                            <description>The state of the I2C bus</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Stop_Bit_Received</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Start_Bit_Received</name>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>RX_ACK</name>
                            <description>Signals if ACK or NACK has been received from a Slave</description>
                            <bitOffset>7</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>ACK_Received</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>NACK_Received</name>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>TXD</name>
                    <displayName>TXD</displayName>
                    <description>Data for Transmission Register</description>
                    <addressOffset>0x00000014</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>TXD</name>
                            <description>Byte to be transmitted via I2C. When address is transmitted zero nit sets the mode^
                            0 - write in a Salve, 1 - read out of a Slave</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CMD</name>
                    <displayName>CMD</displayName>
                    <description>I2C Control Register</description>
                    <addressOffset>0x00000018</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>CLR_INT</name>
                            <description>A write as "1" clears the interrupt</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>ACK</name>
                            <description>Sends ACK</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Send_ACK</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Send_NACK</name>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>WR</name>
                            <description>Writes into the slave device</description>
                            <bitOffset>4</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>RD</name>
                            <description>Reads the data of the slave device</description>
                            <bitOffset>5</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>STOP</name>
                            <description>Sends the stop bit</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>START</name>
                            <description>Sends the start bit</description>
                            <bitOffset>7</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>
        <peripheral>
            <name>ADC</name>
            <description>ADC Controller</description>
            <groupName>ADC</groupName>
            <baseAddress>0x50040000</baseAddress>
            <addressBlock>
                <offset>0x0</offset>
                <size>0x00001000</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>ADC_IRQ</name>
                <value>8</value>
            </interrupt>
            <registers>
                <register>
                    <name>ADC1_CFG</name>
                    <displayName>ADC1_CFG</displayName>
                    <description>ADC1 Configuration Register</description>
                    <addressOffset>0x00000000</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>Cfg_REG_ADON</name>
                            <description>Turns on the ADC1 controller</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>Cfg_REG_GO</name>
                            <description>Starts the conversion</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>Cfg_REG_CLKS</name>
                            <description>Selects ADC clock source</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>ACLK</name>
                                    <description>Selects ACLK as the clock source</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>PCLKd</name>
                                    <description>Selects PCLKd as the clock source</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>Cfg_REG_SAMPLE</name>
                            <description>Selects ADC working mode</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Single</name>
                                    <description>Selects single working mode</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Sequential</name>
                                    <description>Selects sequential working mode</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>Cfg_REG_CHS</name>
                            <description>Selects the analogue channel for conversion</description>
                            <bitOffset>4</bitOffset>
                            <bitWidth>3</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>CH0_ThermoS</name>
                                    <description>CHANNEL_0: Thermosensor</description>
                                    <value>0x7</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH1_SAR_AIN1</name>
                                    <description>CHANNEL_1: SAR_AIN1</description>
                                    <value>0x6</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH2_SAR_AIN2</name>
                                    <description>CHANNEL_2: SAR_AIN2</description>
                                    <value>0x5</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH3_SAR_AIN3</name>
                                    <description>CHANNEL_3: SAR_AIN3</description>
                                    <value>0x4</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH4_TestMode</name>
                                    <description>CHANNEL_4: TestMode</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH5_VDD_BD</name>
                                    <description>CHANNEL_5: VDD_BD</description>
                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH6_VREF</name>
                                    <description>CHANNEL_6: VREF</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CH7_TestMode</name>
                                    <description>CHANNEL_7: TestMode</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>Cfg_REG_CHCH</name>
                            <description>Selects switching of the channels</description>
                            <bitOffset>9</bitOffset>
                            <bitWidth>1</bitWidth>
                        <enumeratedValues>
                            <enumeratedValue>
                                    <name>ON</name>
                                    <description>Channels switching is ON</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>OFF</name>
                                    <description>Only the selected channel is being used</description>
                                    <value>0x0</value>
                            </enumeratedValue>
                        </enumeratedValues>
                        </field>
                        <field>
                            <name>Cfg_REG_RNGC</name>
                            <description>Allows the automatic control of overrunning</description>
                            <bitOffset>10</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>Cfg_M_REF</name>
