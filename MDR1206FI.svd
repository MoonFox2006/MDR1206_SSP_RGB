                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>FE_CHi</name>
                                    <description>A falling edge on the CHi</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>FE_CH_1</name>
                                    <description>A falling edge from other channels: 1-2, 2-3, 3-4, 4-1</description>
                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>FE_CH_2</name>
                                    <description>A falling edge from other channels: 1-3, 2-4, 3-1, 4-2</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CCR1_EN</name>
                            <description>Enables CH_CCR</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                        <field>
                            <name>CCR_RLD</name>
                            <description>Reloading of the CH_CCR and CH_CCR1</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>ANY_MOMENT</name>
                                    <description>Renewal is possible at any moment</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>CNT_0</name>
                                    <description>Renewal is possible when CNT==0</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>EVNT_DLY</name>
                            <description>Delays the capture event until CH_CCR and CH_CCR1 are renewed</description>
                            <bitOffset>4</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>NO_DELAY</name>
                                    <description>An immediate signal of the capture event.
                                    CH_CCR and CH_CCR1 are renewed in a cycle of TIM_CLK</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>DELAY</name>
                                    <description>The capture event is set simultaneously with the renewal of CH_CCR and CH_CCR1</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                    </fields>
