                            <bitWidth>1</bitWidth>
                        <enumeratedValues>
                                <enumeratedValue>
                                    <name>SCALE_VREF</name>
                                    <description>ADC scale from 0 to VREF voltage</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>SCALE_UCCA</name>
                                    <description>ADC scale from 0 to UCCA voltage</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>Cfg_REG_DIVCLK</name>
                            <description>Selects the divisor of PCLK</description>
                            <bitOffset>12</bitOffset>
                            <bitWidth>4</bitWidth>
                        </field>
                        <field>
                            <name>Delay_Go</name>
                            <description>Selects a delay value before the next conversion</description>
                            <bitOffset>25</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>ADC1_H_LEVEL</name>
                    <displayName>ADC1_H_LEVEL</displayName>
                    <description>ADC1 Higher Level Register</description>
                    <addressOffset>0x00000008</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>REG_H_LEVEL</name>
                            <description>ADC1 higher level</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>10</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>ADC1_L_LEVEL</name>
                    <displayName>ADC1_L_LEVEL</displayName>
                    <description>ADC1 Lower Level Register</description>
                    <addressOffset>0x00000010</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>REG_L_LEVEL</name>
                            <description>ADC1 lower level</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>10</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>ADC1_RESULT</name>
                    <displayName>ADC1_RESULT</displayName>
                    <description>ADC1 RESULT Register</description>
                    <addressOffset>0x00000018</addressOffset>
                    <size>0x20</size>
                    <access>read-only</access>
                    <fields>
                        <field>
                            <name>RESULT</name>
                            <description>Conversion result</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>10</bitWidth>
                        </field>
                        <field>
                            <name>CHANNEL</name>
                            <description>Selects the channel to display the result</description>
                            <bitOffset>16</bitOffset>
                            <bitWidth>3</bitWidth>
                        <enumeratedValues>
                            <enumeratedValue>
                                    <name>VREF_R</name>
                                    <description>From 0 to VREF</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>UCCA_R</name>
                                    <description>From 0 to UCCA</description>
                                    <value>0x0</value>
                            </enumeratedValue>
                        </enumeratedValues>
                        </field>
                    </fields>
