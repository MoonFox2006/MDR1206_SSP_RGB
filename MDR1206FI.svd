                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>STOP_BIT_OK</name>
                                    <description>Stop bit has been received correctly</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>STOP_BIT_ERR</name>
                                    <description>The received character did not have a valid stop bit(</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
