                <usage>registers</usage>
            </addressBlock>
            <registers>
                <register>
                    <name>CTMSIP</name>
                    <displayName>CTMSIP</displayName>
                    <description>Software Interrupt Request/Clear Register</description>
                    <addressOffset>0x00000000</addressOffset>
                    <size>32</size>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0x00000001</resetMask>
                    <fields>
                        <field>
                            <name>msip</name>
                            <description>Waiting for software interrupt</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-write</access>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CTMTIMECMP</name>
                    <displayName>CTMTIMECMP</displayName>
                    <description>Machine Timer Comparison Register</description>
                    <addressOffset>0x00004000</addressOffset>
                    <size>64</size>
                    <access>read-write</access>
                    <resetValue>0x0000000000000000</resetValue>
                    <resetMask>0xFFFFFFFFFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>mtimecmp_lo</name>
                            <description>Lower part of the value of the comparison register</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>32</bitWidth>
                            <access>read-write</access>
                        </field>
                        <field>
                            <name>mtimecmp_hi</name>
                            <description>Higher part of the value of the comparison register</description>
                            <bitOffset>32</bitOffset>
                            <bitWidth>32</bitWidth>
                            <access>read-write</access>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CTMTIME</name>
                    <displayName>CTMTIME</displayName>
                    <description>Machine Timer Value Register</description>
                    <addressOffset>0x0000BFF8</addressOffset>
                    <size>64</size>
                    <access>read-write</access>
                    <resetValue>0x0000000000000000</resetValue>
                    <resetMask>0xFFFFFFFFFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>mtime_lo</name>
                            <description>Lower part of the timer value</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>32</bitWidth>
                            <access>read-write</access>
                        </field>
                        <field>
                            <name>mtime_hi</name>
                            <description>Higher part of the timer value</description>
                            <bitOffset>32</bitOffset>
                            <bitWidth>32</bitWidth>
                            <access>read-write</access>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>
        <peripheral>
            <name>CLIC</name>
            <description>Core Local Interrupt Controller</description>
            <groupName>CLIC</groupName>
            <baseAddress>0x0D000000</baseAddress>
            <addressBlock>
                <offset>0x0</offset>
                <size>0x00008000</size>
                <usage>registers</usage>
            </addressBlock>
            <registers>
                <register>
                    <name>CLICCFG</name>
                    <displayName>CLICCFG</displayName>
                    <description>CLIC Configuration Register</description>
                    <addressOffset>0x00000000</addressOffset>
                    <size>0x8</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>NVBITS</name>
                            <description>Function of Nested Vectored Interrupt</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-only</access>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>NVI_function</name>
                                    <description>NVI is available</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>No_NVI_function</name>
                                    <description>NVI isn't available</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>NLBITS</name>
                            <description>The number of higher-order bits in clicintctl[i] used to set interrupt level</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>4</bitWidth>
                        </field>
                        <field>
                            <name>NMBITS</name>
                            <description>The number of bits in clicintattr[i].mode to set prior entrance for i</description>
                            <bitOffset>5</bitOffset>
                            <bitWidth>2</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CLICINFO</name>
                    <displayName>CLICINFO</displayName>
                    <description>CLIC Information Register</description>
                    <addressOffset>0x00000004</addressOffset>
                    <size>0x20</size>
                    <access>read-only</access>
                    <fields>
                        <field>
                            <name>NUM_INTERRUPT</name>
                            <description>The maximum number of interrupt input signals</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>13</bitWidth>
                        </field>
                        <field>
                            <name>VERSION</name>
                            <description>CLIC version</description>
                            <bitOffset>13</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                        <field>
                            <name>CLICINTCTLBITS</name>
                            <description>The number of bits in clicintctl[i]</description>
                            <bitOffset>21</bitOffset>
                            <bitWidth>4</bitWidth>
                        </field>
                        <field>
                            <name>NUM_TRIGGER</name>
                            <description>The maximun number of interrupt triggers</description>
                            <bitOffset>25</bitOffset>
                            <bitWidth>6</bitWidth>
                        </field>
                    </fields>
                </register>
                <register>
                    <name>CLICINT_0</name>
                    <displayName>CLICINT[0]_USIP</displayName>
                    <description>Software interrupt for user priority mode</description>
                    <addressOffset>0x00001000</addressOffset>
                    <size>0x20</size>
                    <access>read-write</access>
                    <fields>
                        <field>
                            <name>CLICINTIP_IP</name>
                            <description>Interrupt pending</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>IP_ON</name>
                                    <description>Interrupt pending is on</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Int_OFF</name>
                                    <description>Interrupt pending is off</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CLICINTIE_IE</name>
                            <description>Interrupt enable</description>
                            <bitOffset>8</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>Int_ON</name>
                                    <description>Interrupt is on</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>Int_OFF</name>
                                    <description>Interrupt is off</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CLICINTATTR_SHV</name>
                            <description>Selection of the vectored interrup</description>
                            <bitOffset>16</bitOffset>
                            <bitWidth>1</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>VEC</name>
                                    <description>Vectored interrupt</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>NON_VEC</name>
                                    <description>Non-vectored interrupt</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CLICINTATTR_TRIG</name>
                            <description>Trigger type and polarity for every interrupt</description>
                            <bitOffset>17</bitOffset>
                            <bitWidth>2</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>HIGH_LEV</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>POS_EDGE</name>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>LOW_LEV</name>
                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>NEG_EDGE</name>
                                    <value>0x3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CLICINTATTR_MODE</name>
                            <description>Mode of the privileged interrupt</description>
                            <bitOffset>22</bitOffset>
                            <bitWidth>2</bitWidth>
                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>U_MODE</name>
                                    <description>User</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>M_MODE</name>
                                    <description>Machine</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>CLICINTCTL_LEVEL_PRIORITY</name>
                            <description>Interrupt level and priority</description>
                            <bitOffset>24</bitOffset>
                            <bitWidth>8</bitWidth>
                        </field>
                    </fields>
