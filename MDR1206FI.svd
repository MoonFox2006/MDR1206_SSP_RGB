                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>BREAK_ERR</name>
                                    <description>A break condition was detected</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field>
                            <name>OE</name>
                            <description>Overrun error</description>
