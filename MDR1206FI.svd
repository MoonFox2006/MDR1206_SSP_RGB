                            <enumeratedValues>
                                <enumeratedValue>
                                    <name>NO_TESTING_SYSTEM</name>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TESTING_SYSTEM</name>
                                    <value>0x1</value>
                                </enumeratedValue>
                            </enumeratedValues>
